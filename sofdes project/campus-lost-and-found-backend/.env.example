# ===========================================================================
# Campus Lost and Found System - Backend Environment Configuration (EXAMPLE)
# ---------------------------------------------------------------------------
# Copy this file to ".env" and fill in real values.
# NEVER commit the real ".env" file to version control.
# ===========================================================================

# --- Server ---------------------------------------------------------------
PORT=5000
NODE_ENV=development

# --- Database (MySQL) -----------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=campus_lost_and_found
DB_CONNECTION_LIMIT=10

# --- Authentication (JWT) -------------------------------------------------
# Use a long, random string for JWT_SECRET in production.
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=1d

# --- Security -------------------------------------------------------------
# bcrypt cost factor (number of salt rounds). 10-12 is recommended.
BCRYPT_SALT_ROUNDS=10

# --- CORS -----------------------------------------------------------------
# Frontend origin allowed to call this API (Vite dev server default shown).
CORS_ORIGIN=http://localhost:5173
