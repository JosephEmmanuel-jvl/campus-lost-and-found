{
  "name": "campus-lost-and-found-backend",
  "version": "1.0.0",
  "description": "Backend foundation for the Campus Lost and Found System (Group 6). Express.js + MySQL REST API implementing the approved Entity List and API Specification.",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:schema": "mysql -u %DB_USER% -p %DB_NAME% < database/schema.sql",
    "db:seed": "mysql -u %DB_USER% -p %DB_NAME% < database/seed.sql"
  },
  "keywords": [
    "lost-and-found",
    "express",
    "mysql",
    "rest-api",
    "campus"
  ],
  "author": "Group 6 - Member 6 (Database & Backend Support)",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.11.0",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
